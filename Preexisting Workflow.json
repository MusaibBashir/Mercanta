      "parameters": {
        "jsCode": "const raw = ($input.item.json.text || '').trim();\nconst texMatch = raw.match(/(\\\\documentclass[\\s\\S]*?\\\\end\\{document\\})/i);\nconst texContent = texMatch ? texMatch[1].trim() : raw.trim();\nconst plainMatch = raw.match(/PLAIN_ANSWER:\\s*(.+)/i);\nconst plainAnswer = plainMatch ? plainMatch[1].trim() : 'See .tex in knowledge base';\nreturn [{ json: { texContent, plainAnswer } }];"
      },
