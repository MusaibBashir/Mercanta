    {
      "parameters": {
        "jsCode": "const quoted = $('Extract Variables').item.json.quotedMessage;\nconst command = $('Extract Variables').item.json.commandRaw;\nconst isoNow = new Date().toISOString();\nconst prompt = `You are a calendar assistant. Today is ${isoNow}. Timezone: Asia/Kolkata (UTC+5:30).\nParse this message and extract event details.\nMessage: ${quoted}\nContext: ${command}\nSTRICT RULES:\n- Use ONLY the date and time explicitly written in the message.\n- Current year is 2026. If no time given use 09:00:00. End = start + 1hr if not specified.\n- Include +05:30 offset in all datetimes.\n- event_title: short clear title from the message content.\n- summary: one concise sentence about the event.\nReturn ONLY this raw JSON, no markdown, no explanation:\n{\"event_title\":\"title\",\"start\":\"YYYY-MM-DDTHH:mm:ss+05:30\",\"end\":\"YYYY-MM-DDTHH:mm:ss+05:30\",\"summary\":\"one sentence\"}`;\nreturn [{ json: { prompt } }];"
      },
      "id": "07eeacbb-796a-419b-a820-4be31192556d",
      "name": "Build Event Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        25488,
        11728
      ]
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nif (!rows || rows.length === 0) return [{ json: { prompt: '', messageCount: 0 } }];\nconst discussion = rows.filter(r => r.json?.content).map((r,i) => `[${i+1}] ${r.json.content}`).join('\\n');\nconst messageCount = rows.length;\nconst today = new Date().toISOString().split('T')[0];\nconst prompt = `You are a film analysis assistant. Below is a real WhatsApp discussion about a movie.\nDiscussion (${messageCount} messages):\n${discussion}\nReturn ONLY a valid JSON object, no markdown fences:\n{\"title\":\"exact movie name\",\"themes\":[\"theme\"],\"opinions\":[\"opinion\"],\"sentiment\":\"positive\",\"rewatch\":\"yes\",\"summary\":\"2-3 sentences\",\"discussed_at\":\"${today}\"}\nRules: title = actual movie name from messages. Only use content from messages above.`;\nreturn [{ json: { prompt, messageCount } }];"
      },
      "id": "474a81fd-642b-49c7-a36a-734c306193b5",
      "name": "Build Film Prompt",
      "type": "n8n-nodes-base.code",
