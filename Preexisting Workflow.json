    {
      "parameters": {
        "jsCode": "const quoted = $('Extract Variables').item.json.quotedMessage;\nconst prompt = `You are an expert mathematician and LaTeX typesetter.\nSolve the following and return a complete compilable .tex document.\nContent: ${quoted}\nInclude: \\\\documentclass{article}, \\\\usepackage{amsmath,amssymb,amsthm}, Problem section, Solution section with all steps.\nAfter the document write: PLAIN_ANSWER: <concise answer>`;\nreturn [{ json: { prompt } }];"
      },
