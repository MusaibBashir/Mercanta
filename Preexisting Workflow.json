    {
      "parameters": {
        "jsCode": "const body = $input.item.json.body;\nconst msgData = body.data;\nconst msg = msgData.message || {};\n\nconst sender = msgData.key.remoteJid;\n\n// Command = what the user typed\nlet commandRaw = '';\nif (msg.extendedTextMessage?.text) {\n  commandRaw = msg.extendedTextMessage.text;\n} else if (msg.conversation) {\n  commandRaw = msg.conversation;\n}\ncommandRaw = commandRaw.trim().toLowerCase();\n\n// Quoted message - the content being tagged\nlet quotedMessage = '';\nif (msgData.contextInfo?.quotedMessage?.conversation) {\n  quotedMessage = msgData.contextInfo.quotedMessage.conversation;\n} else if (msgData.contextInfo?.quotedMessage?.extendedTextMessage?.text) {\n  quotedMessage = msgData.contextInfo.quotedMessage.extendedTextMessage.text;\n} else if (msg.extendedTextMessage?.contextInfo?.quotedMessage?.conversation) {\n  quotedMessage = msg.extendedTextMessage.contextInfo.quotedMessage.conversation;\n} else if (msg.extendedTextMessage?.contextInfo?.quotedMessage?.extendedTextMessage?.text) {\n  quotedMessage = msg.extendedTextMessage.contextInfo.quotedMessage.extendedTextMessage.text;\n}\n\nreturn [{ json: {\n  ...($input.item.json),\n  sender,\n  commandRaw,\n  quotedMessage\n}}];"
      },
